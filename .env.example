# ── Takumi Autonomy — 環境変数テンプレート ──────────────────────────────────
# このファイルを .env にコピーして値を埋めること。
# .env は .gitignore 済み (secrets を commit しないこと)。

# Discord Bot トークン (必須)
DISCORD_TOKEN=your-discord-bot-token-here

# Anthropic API キー (TAKUMI_EXECUTOR=api 時に必要)
# 省略するとスタブモードで動作する
ANTHROPIC_API_KEY=

# Executor バックエンド: claude-code (推奨) / api / 未設定=スタブ
TAKUMI_EXECUTOR=claude-code

# Discord サーバー ID — スラッシュコマンドをそのサーバーに即時反映する（推奨）
# 未設定の場合はグローバル sync（最大 1 時間かかる）
DISCORD_GUILD_ID=

# 自然言語チャット用チャンネル — ここに書いたチャンネルでは
# /task コマンド不要で普通に話しかけるとスレッドで応答する
# 複数ある場合はカンマ区切り: 123456789,987654321
DISCORD_TASK_CHANNELS=

# 認証通知チャンネル — Claude Code の認証が切れたときに通知するチャンネル（任意）
# 未設定の場合は Bot が参加している最初のテキストチャンネルに送信
DISCORD_AUTH_CHANNEL_ID=