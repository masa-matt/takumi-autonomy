# ── Takumi Autonomy — 環境変数テンプレート ──────────────────────────────────
# このファイルを .env にコピーして値を埋めること。
# .env は .gitignore 済み (secrets を commit しないこと)。

# Discord Bot トークン (必須)
DISCORD_TOKEN=your-discord-bot-token-here

# Anthropic API キー (AgentSdkExecutor を使う場合)
# 省略するとスタブモードで動作する
ANTHROPIC_API_KEY=

# Executor バックエンド: agent-sdk (デフォルト) / claude-code
TAKUMI_EXECUTOR=agent-sdk
